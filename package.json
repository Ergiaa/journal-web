{
  "name": "journal-web",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"bun run dev:api\" \"bun run dev:web\"",
    "dev:api": "cd apps/api && bun run dev",
    "dev:web": "cd apps/web && bun run dev",
    "build": "bun run --filter '*' build",
    "lint": "bun run --filter '*' lint",
    "typecheck": "bun run --filter '*' typecheck",
    "infra:up": "docker-compose -f docker-compose.dev.yml up -d",
    "infra:down": "docker-compose -f docker-compose.dev.yml down",
    "infra:logs": "docker-compose -f docker-compose.dev.yml logs -f",
    "infra:ps": "docker-compose -f docker-compose.dev.yml ps",
    "infra:restart": "docker-compose -f docker-compose.dev.yml restart",
    "infra:clean": "docker-compose -f docker-compose.dev.yml down -v"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5"
  }
}
