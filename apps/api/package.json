{
  "name": "journal-web-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "start": "bun run dist/index.js",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@types/pg": "^8.20.0",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.28",
    "ioredis": "^5.10.1",
    "journal-web-crawler": "workspace:*",
    "journal-web-workers": "workspace:*",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "typescript": "^5",
    "typescript-eslint": "^8.57.1"
  }
}
