# ============================================
# Journal Web - Environment Variables Template
# ============================================
# Copy this file to .env and fill in your actual values
# 
# This file contains ALL required environment variables
# for the complete application stack (API, Web, Workers, Crawler)

# ============================================
# Database Configuration (Docker Compose Dev)
# ============================================
POSTGRES_USER=journal
POSTGRES_PASSWORD=journal
POSTGRES_DB=journal_db
DATABASE_URL=postgresql://journal:journal@localhost:5432/journal_db

# ============================================
# Redis Configuration (Cache & Job Queues)
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# Application URLs
# ============================================
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
PORT=3001

# ============================================
# Crawler Configuration
# ============================================
CRAWLER_ARXIV_RATE_LIMIT_MS=3000
CRAWLER_BATCH_SIZE=100
CRAWLER_MAX_RESULTS_PER_QUERY=2000

# ============================================
# Workers Configuration
# ============================================
WORKER_CONCURRENCY=5

# ============================================
# Scheduler Configuration (Cron)
# ============================================
# Daily crawl at 2:00 AM
CRON_CRAWL_DAILY=0 2 * * *

# Weekly citation update at 4:00 AM on Sundays
CRON_CITATIONS_WEEKLY=0 4 * * 0

# Timezone for scheduler (default: UTC)
TZ=UTC

# ============================================
# External Services (Planned for Future)
# ============================================
ML_SERVICE_URL=http://localhost:8000

# ============================================
# Optional: Semantic Scholar API (for future citation updates)
# ============================================
# SEMANTIC_SCHOLAR_API_KEY=your_api_key_here
